{
    "name": "Project Dev Container",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "remoteUser": "vscode",
    "mounts": [
        "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,readonly",
        "source=${localEnv:HOME}/.claude/settings.json,target=/home/vscode/.claude/settings.json,type=bind,readonly",
        "source=${localEnv:HOME}/.claude/statusline.js,target=/home/vscode/.claude/statusline.js,type=bind,readonly"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "anthropic.claude-code"
            ]
        }
    },
    "postCreateCommand": "git config --global --add safe.directory ${containerWorkspaceFolder} && git config --global user.name 'Amin Lakhani' && git config --global user.email '85595676+amin-lakhani@users.noreply.github.com'"
}
